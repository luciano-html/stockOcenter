PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/stock-office-center

# Seguridad: generar con openssl rand -base64 32
JWT_SECRET=change-this-secret
REFRESH_TOKEN_SECRET=change-this-refresh-secret

# CORS: separar orígenes con comas. Ej: http://localhost:5173,https://miapp.com
CORS_ORIGINS=http://localhost:5173

# Cookies: en producción poner secure=true y sameSite=strict
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
